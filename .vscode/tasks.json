{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "(dev) Start DAC PostgreSQL",
            "type": "shell",
            "command": [
                "cd backend/",
                "&&",
                "podman run -it --rm --name dac_postgres",
                "-e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=password -e POSTGRES_DB=dac -p 5431:5432",
                "-v ./dac_web/db/:/docker-entrypoint-initdb.d/",
                "postgres"
            ],
            "problemMatcher": []
        },
        {
            "label": "(dev) Start DAC backend",
            "type": "shell",
            "command": [
                "cd backend",
                "&&",
                "until pg_isready -h localhost -p 5431; do echo 'Waiting for Postgres...'; sleep 1; done",
                "&&",
                "uv run uvicorn --reload --port=8031 dac_web.main:app"
            ],
            "problemMatcher": [
                "$python"
            ],
            "options": {
                "env": {
                    "APP_LOG_ON": "1",
                    "DBSTORE": "true",
                    "LOG_DIR": "../storage/logs/",
                    "PROJECT_DIR": "../storage/projects/",
                    "POSTGRES_PORT": "5431",
                    "KEYCLOAK_URL": "http://localhost:8080",
                    "KEYCLOAK_REALM": "miz",
                    "KEYCLOAK_CLIENT_ID": "dac-frontend",
                    "KEYCLOAK_CLIENT_SECRET": "",
                }
            }
        },
        {
            "label": "(dev) Start DAC frontend",
            "type": "shell",
            "command": [
                "cd dac-frontend",
                "&&",
                "until /bin/nc -z localhost 8031; do sleep 1; done",
                "&&",
                "pnpm run dev --port 5131 --open",
            ],
            "options": {
                "env": {
                    "VITE_API_PORT": "8031"
                }
            },
            "problemMatcher": [
                "$tsc"
            ]
        },
        {
            "label": "🚀 DAC",
            "dependsOrder": "parallel",
            "dependsOn": [
                "(dev) Start DAC PostgreSQL",
                "(dev) Start DAC backend",
                "(dev) Start DAC frontend"
            ],
            "group": {
                "kind": "build",
            }
        },
    ]
}